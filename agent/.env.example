AGENT_STELLAR_SECRET=your_agent_secret_key
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
LODESTAR_API_URL=http://localhost:3001
# HMAC secret for signing payment-record requests (must match backend's SERVER_STELLAR_SECRET)
LODESTAR_HMAC_SECRET=your_server_secret_key

# Optional agent identity (displayed in logs and registered on-chain)
AGENT_NAME=LodestarAgent
AGENT_DESC=Autonomous x402 agent powered by Lodestar service discovery


AGENT_MAX_PER_TX=0.001
AGENT_MAX_PER_DAY=1.00


AGENT_ALLOWED_CATEGORIES=weather,search

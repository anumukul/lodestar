# Backend base URL (used by update-endpoints.js to replace localhost endpoints on-chain)
BACKEND_URL=https://lodestar-8na4.onrender.com

NODE_ENV=development
PORT=3001
LOG_LEVEL=info
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Service Registry contract (deploy from contract/)
CONTRACT_ID=your_deployed_registry_contract_id_here

# Agent Credit Scoring contract (deploy from contract/agents/)
AGENTS_CONTRACT_ID=your_deployed_agents_contract_id_here

# Server Stellar keypair (receives x402 payments)
SERVER_STELLAR_ADDRESS=your_server_public_key
SERVER_STELLAR_SECRET=your_server_secret_key

FACILITATOR_URL=https://www.x402.org/facilitator
SEARCH_PRICE=0.001
WEATHER_PRICE=0.001
BRAVE_API_KEY=your_serper_api_key
# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://app.example.com)
CORS_ORIGIN=http://localhost:3000
# JSON body size limit (default 100kb)
JSON_BODY_LIMIT=100kb
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Express "trust proxy" setting — set to the number of reverse-proxy hops in
# front of the app (e.g. 1 on Render/Heroku/nginx) so rate limiting sees the
# real client IP. "true"/"false" or an IP/subnet list also work. Default: false.
TRUST_PROXY=1

# ── Rate limiting for public write endpoints (anti-spam for on-chain writes) ──
# Generic limit for POST /api/reputation/:id and POST /api/agents/register.
# Exceeding the limit returns HTTP 429 with code RATE_LIMITED.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
# Tighter, per-agent limit for POST /api/agents/:address/payment.
PAYMENT_RATE_LIMIT_WINDOW_MS=60000
PAYMENT_RATE_LIMIT_MAX=10

# ── Demo-run activity poll (POST /api/demo-run txHash lookup) ──
# DEMO_RUN_POLL_MAX_WAIT_MS=8000
# DEMO_RUN_POLL_INITIAL_DELAY_MS=250
# DEMO_RUN_POLL_MAX_DELAY_MS=2000

# Optional: pre-funded demo agent secrets for seed-agents script
# If omitted, seed script generates ephemeral random keypairs
DEMO_AGENT_1_SECRET=
DEMO_AGENT_2_SECRET=
DEMO_AGENT_3_SECRET=

# ── Reputation voting (POST /api/reputation/:id) ──────────────────────────────
# Reputation votes are authorized on-chain: the contract requires the vote to be
# signed by a registered agent (caller.require_auth() + cross-contract
# is_registered) and rate-limits repeat votes per (service, agent). The hosted
# backend can therefore only cast votes for agents whose secret keys it holds.
#
# The SERVER_STELLAR_SECRET key always doubles as a demo voter. To allow extra
# pre-funded, on-chain-registered demo agents to vote via the backend, list their
# secrets here (comma-separated). Every derived address must be a registered
# agent (see scripts/seed-agents.js) and a funded testnet account.
DEMO_VOTER_SECRETS=

# ── HMAC request signing (interim auth for POST /api/agents/:address/payment) ──
# The X-Lodestar-Signature header must be HMAC-SHA256(JSON body, secret).
# The singing secret is config.server.secret (SERVER_STELLAR_SECRET above).
# The agent.js client reads LODESTAR_HMAC_SECRET from its own .env and signs
# each payment-record request. See backend/src/middleware/hmacAuth.js.
#
# Signing scheme:
#   crypto.createHmac('sha256', secret).update(JSON.stringify(body)).digest('hex')

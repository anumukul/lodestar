# Backend base URL (used by update-endpoints.js to replace localhost endpoints on-chain)
BACKEND_URL=https://lodestar-8na4.onrender.com

NODE_ENV=development
PORT=3001
LOG_LEVEL=info
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Service Registry contract (deploy from contract/)
CONTRACT_ID=your_deployed_registry_contract_id_here

# Agent Credit Scoring contract (deploy from contract/agents/)
AGENTS_CONTRACT_ID=your_deployed_agents_contract_id_here

# Server Stellar keypair (receives x402 payments)
SERVER_STELLAR_ADDRESS=your_server_public_key
SERVER_STELLAR_SECRET=your_server_secret_key

FACILITATOR_URL=https://www.x402.org/facilitator
SEARCH_PRICE=0.001
WEATHER_PRICE=0.001
BRAVE_API_KEY=your_serper_api_key
# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://app.example.com)
CORS_ORIGIN=http://localhost:3000
# JSON body size limit (default 100kb)
JSON_BODY_LIMIT=100kb
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Optional: pre-funded demo agent secrets for seed-agents script
# If omitted, seed script generates ephemeral random keypairs
DEMO_AGENT_1_SECRET=
DEMO_AGENT_2_SECRET=
DEMO_AGENT_3_SECRET=

# ── HMAC request signing (interim auth for POST /api/agents/:address/payment) ──
# The X-Lodestar-Signature header must be HMAC-SHA256(JSON body, secret).
# The singing secret is config.server.secret (SERVER_STELLAR_SECRET above).
# The agent.js client reads LODESTAR_HMAC_SECRET from its own .env and signs
# each payment-record request. See backend/src/middleware/hmacAuth.js.
#
# Signing scheme:
#   crypto.createHmac('sha256', secret).update(JSON.stringify(body)).digest('hex')
